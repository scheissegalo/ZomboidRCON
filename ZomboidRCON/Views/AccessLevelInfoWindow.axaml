<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZomboidRCON.Views.AccessLevelInfoWindow"
        Title="Access Levels"
        Width="450" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Icon="/Assets/Icons/icon.ico">

    <ScrollViewer Margin="16">
        <StackPanel Spacing="8">
            <TextBlock Text="Project Zomboid Access Levels" FontSize="16" FontWeight="Bold"/>
            <TextBlock TextWrapping="Wrap"/>
            <TextBlock Text="" Margin="0,4"/>
            <TextBlock Text="For more information, visit:"/>
            <TextBlock x:Name="LinkLabel" Text="https://pzwiki.net/wiki/Access_level"
                       Classes="hyperlink" Cursor="Hand" PointerPressed="OnLinkClick"/>
        </StackPanel>
    </ScrollViewer>
</Window>
