<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ZomboidRCON"
        x:Class="ZomboidRCON.Views.MainWindow"
        Title="Zomboid Admin Tool"
        Width="500" Height="550"
        MinWidth="400" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/Icons/icon.ico">

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Server Controls">
                <MenuItem Header="_Command Console" Click="OnCommandConsoleClick"/>
                <MenuItem Header="Show _Options" Click="OnShowOptionsClick"/>
                <MenuItem Header="_Reload Options" Click="OnReloadOptionsClick"/>
            </MenuItem>
            <MenuItem Header="_Database Tools" IsEnabled="False">
                <MenuItem Header="_Create Items Pack" IsEnabled="False"/>
                <MenuItem Header="_Open Items Pack" IsEnabled="False"/>
                <MenuItem Header="_Import Items Pack" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="Ma_p" Click="OnMapClick"/>
            <MenuItem Header="_Help">
                <MenuItem Header="_Information">
                    <MenuItem Header="_Access Levels" Click="OnAccessLevelsClick"/>
                </MenuItem>
                <MenuItem Header="_Report Issue" Click="OnReportIssueClick"/>
                <MenuItem Header="_Credits" Click="OnCreditsClick"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="8,4" Margin="8,4,8,0">
            <TextBlock x:Name="StatusText" Text="Not connected" Foreground="#AAAAAA" FontSize="12"/>
        </Border>

        <!-- Bottom Controls (must be before the fill element) -->
        <DockPanel DockPanel.Dock="Bottom" Margin="8,4,8,8" Height="50">
            <Button DockPanel.Dock="Right"
                    x:Name="RefreshBtn"
                    Content="&#x21BB;"
                    Width="50" Height="40"
                    FontSize="22"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="OnRefreshClick"
                    Cursor="Hand"
                    Margin="4,0,0,0"/>

            <StackPanel DockPanel.Dock="Left" Orientation="Vertical" VerticalAlignment="Bottom">
                <TextBlock Text="Refresh Rate" Margin="0,0,0,2"/>
                <ComboBox x:Name="RefreshRateCombo" Width="120"
                          SelectionChanged="OnRefreshRateChanged">
                    <ComboBoxItem Content="5 Sec"/>
                    <ComboBoxItem Content="30 Sec"/>
                    <ComboBoxItem Content="60 Sec"/>
                </ComboBox>
            </StackPanel>
        </DockPanel>

        <!-- Player List (LAST child = fill remaining space) -->
        <DataGrid
                  x:Name="PlayersGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  Margin="8,4,8,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Player Name" Binding="{Binding Name}" Width="*"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Kick Player" Click="OnKickPlayer"/>
                    <MenuItem Header="Add to Whitelist" Click="OnAddToWhitelist"/>
                    <Separator/>
                    <MenuItem Header="Set Access Level">
                        <MenuItem Header="None" Click="OnSetAccessNone"/>
                        <MenuItem Header="Overseer" Click="OnSetAccessOverseer"/>
                        <MenuItem Header="GM" Click="OnSetAccessGM"/>
                        <MenuItem Header="Moderator" Click="OnSetAccessModerator"/>
                        <MenuItem Header="Admin" Click="OnSetAccessAdmin"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Enable Godmode" Click="OnEnableGodmode"/>
                    <MenuItem Header="Disable Godmode" Click="OnDisableGodmode"/>
                    <Separator/>
                    <MenuItem Header="Spawn Vehicle" Click="OnSpawnVehicle"/>
                    <MenuItem Header="Give Item" Click="OnGiveItem"/>
                    <Separator/>
                    <MenuItem Header="Teleport to Player" Click="OnTeleportToPlayer"/>
                    <MenuItem Header="Teleport to Coordinates" Click="OnTeleportToCoords"/>
                    <MenuItem Header="Add Experience" Click="OnAddExp"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </DockPanel>
</Window>
