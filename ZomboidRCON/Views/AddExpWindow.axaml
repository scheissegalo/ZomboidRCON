<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZomboidRCON.Views.AddExpWindow"
        Title="Add Experience"
        Width="350" Height="150"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Icon="/Assets/Icons/icon.ico">

    <StackPanel Margin="16" Spacing="8">
        <TextBlock Text="Perk:" FontWeight="Bold"/>
        <ComboBox x:Name="PerkCombo"/>

        <TextBlock Text="XP Amount:" FontWeight="Bold"/>
        <NumericUpDown x:Name="NumExp" Minimum="1" Maximum="99999" Value="100"/>

        <Button x:Name="BtnGiveExp" Content="Give EXP" Height="30" Click="OnGiveExpClick"/>
    </StackPanel>
</Window>
