<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZomboidRCON.Views.UpdateWindow"
        Title="Update Available"
        Width="450" Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Icon="/Assets/Icons/icon.ico">

    <StackPanel Margin="16" Spacing="8">
        <TextBlock Text="New update details:" FontWeight="Bold"/>
        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="DetailsTxt" IsReadOnly="True" TextWrapping="Wrap"
                     AcceptsReturn="True"/>
        </ScrollViewer>
        <ProgressBar x:Name="DownloadBar" IsVisible="False" Height="20" Minimum="0" Maximum="100"/>
        <TextBlock x:Name="UpdateLabel" Text=""/>
        <DockPanel>
            <TextBlock x:Name="SizeLbl" Text="Size: xxxx mb" DockPanel.Dock="Left"/>
            <TextBlock x:Name="VersionLbl" Text="vx.y.z" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
        </DockPanel>
        <Button x:Name="DownloadBtn" Content="Download and install" Height="35"
                Click="OnDownloadClick"/>
    </StackPanel>
</Window>
